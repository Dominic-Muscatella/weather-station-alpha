[Unit]
Description=Primary LED Control Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/<username>/weather_station_alpha
ExecStart=/home/<username>/weather_station_alpha/weather_env/bin/python /home/<username>/weather_station_alpha/light_control.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target